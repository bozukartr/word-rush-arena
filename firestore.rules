rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function roomExistsAfter(code) { return existsAfter(/databases/$(database)/documents/rooms/$(code)); }
    function isPlayer(code) { return signedIn() && exists(/databases/$(database)/documents/rooms/$(code)/players/$(request.auth.uid)); }
    function isHost(code) { return signedIn() && get(/databases/$(database)/documents/rooms/$(code)).data.hostId == request.auth.uid; }
    function validPowerUse(uid) {
      let action = request.resource.data.lastAction;
      let code = action.roomCode;
      let round = action.round;
      let inventoryBefore = resource.data.get('inventory', {'a_lock': 0});
      let playerBefore = get(/databases/$(database)/documents/rooms/$(code)/players/$(uid)).data;
      let playerAfter = getAfter(/databases/$(database)/documents/rooms/$(code)/players/$(uid)).data;
      let effectAfter = getAfter(/databases/$(database)/documents/rooms/$(code)/effects/$(uid)).data;
      return action.type == 'power'
        && action.itemId == 'a_lock'
        && action.roomCode is string
        && action.round is int
        && request.resource.data.coins == resource.data.coins
        && request.resource.data.diamonds == resource.data.get('diamonds', 0)
        && request.resource.data.inventory.a_lock == inventoryBefore.get('a_lock', 0) - 1
        && get(/databases/$(database)/documents/rooms/$(code)).data.phase == 'playing'
        && playerBefore.get('attackUsedRound', -1) != round
        && playerAfter.attackUsedRound == round
        && effectAfter.ownerId == uid
        && effectAfter.round == round;
    }
    function marketPrice(itemId) {
      return itemId == 'aurora' ? 3 : itemId == 'obsidian' ? 5 : itemId == 'royal' ? 8 : 0;
    }
    function validMarketPurchase() {
      let action = request.resource.data.lastAction;
      let inventoryBefore = resource.data.get('inventory', {'a_lock': 0});
      let themesBefore = resource.data.get('ownedThemes', ['default']);
      let themePrice = marketPrice(action.itemId);
      return action.type == 'market' && (
        (
          action.itemId == 'a_lock'
          && action.currency == 'coins'
          && action.price == 25
          && request.resource.data.coins == resource.data.coins - 25
          && request.resource.data.diamonds == resource.data.get('diamonds', 0)
          && request.resource.data.inventory.a_lock == inventoryBefore.get('a_lock', 0) + 1
        ) || (
          themePrice > 0
          && action.currency == 'diamonds'
          && action.price == themePrice
          && request.resource.data.coins == resource.data.coins
          && request.resource.data.diamonds == resource.data.get('diamonds', 0) - themePrice
          && request.resource.data.ownedThemes.hasAny([action.itemId])
          && request.resource.data.ownedThemes.size() == themesBefore.size() + 1
        )
      );
    }
    function validRoundReward(uid) {
      let action = request.resource.data.lastAction;
      let code = action.roomCode;
      let round = action.round;
      let room = get(/databases/$(database)/documents/rooms/$(code)).data;
      let playerBefore = get(/databases/$(database)/documents/rooms/$(code)/players/$(uid)).data;
      let playerAfter = getAfter(/databases/$(database)/documents/rooms/$(code)/players/$(uid)).data;
      let reward = room.winnerId == uid ? 40 : 5;
      let winIncrement = room.winnerId == uid ? 1 : 0;
      let nextWins = resource.data.get('wins', 0) + winIncrement;
      let diamondIncrement = room.winnerId == uid && nextWins % 3 == 0 ? 1 : 0;
      return action.type == 'reward'
        && action.roomCode is string
        && action.round is int
        && room.phase == 'results'
        && room.round == round
        && playerBefore.get('rewardedRound', -1) != round
        && playerAfter.rewardedRound == round
        && request.resource.data.coins == resource.data.coins + reward
        && request.resource.data.wins == nextWins
        && request.resource.data.diamonds == resource.data.get('diamonds', 0) + diamondIncrement;
    }

    match /rooms/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.phase == 'lobby';
      allow update: if isPlayer(code) && (
        isHost(code) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt']) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hostId', 'updatedAt'])
          && request.resource.data.hostId == request.auth.uid
          && get(/databases/$(database)/documents/rooms/$(code)/players/$(resource.data.hostId)).data.connected == false
        )
      );
      allow delete: if isHost(code);

      match /players/{uid} {
        allow read: if signedIn();
        allow create: if signedIn() && request.auth.uid == uid && roomExistsAfter(code);
        allow update: if signedIn() && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'ready', 'connected', 'lastSeenAt', 'score', 'words', 'round', 'letters', 'letterBag', 'boardVersion', 'boardRound', 'attackUsedRound', 'rewardedRound']);
        allow delete: if signedIn() && (request.auth.uid == uid || isHost(code));
      }

      match /submissions/{word} {
        allow read: if isPlayer(code);
        allow create: if isPlayer(code)
          && request.resource.data.ownerId == request.auth.uid
          && request.resource.data.points is int
          && request.resource.data.points >= 0
          && request.resource.data.points <= 2000;
        allow update: if false;
        allow delete: if isHost(code);
      }

      match /effects/{effectId} {
        allow read: if isPlayer(code);
        allow create, update: if isPlayer(code)
          && effectId == request.auth.uid
          && request.resource.data.ownerId == request.auth.uid
          && request.resource.data.targetId != request.auth.uid
          && request.resource.data.type == 'block_letter'
          && request.resource.data.letter == 'A'
          && request.resource.data.round is int
          && request.resource.data.expiresAt is timestamp
          && get(/databases/$(database)/documents/rooms/$(code)).data.phase == 'playing'
          && exists(/databases/$(database)/documents/rooms/$(code)/players/$(request.resource.data.targetId))
          && getAfter(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.inventory.a_lock
            == get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('inventory', {'a_lock': 0}).get('a_lock', 0) - 1
          && getAfter(/databases/$(database)/documents/rooms/$(code)/players/$(request.auth.uid)).data.attackUsedRound
            == request.resource.data.round
          && (!exists(/databases/$(database)/documents/rooms/$(code)/effects/$(effectId))
            || request.resource.data.round > resource.data.round);
        allow delete: if isHost(code);
      }

      match /rounds/{roundNumber} {
        allow read: if isPlayer(code);
        allow create, update: if isHost(code)
          && request.resource.data.round is int
          && request.resource.data.players is list;
        allow delete: if isHost(code);
      }
    }

    match /profiles/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.coins == 0
        && request.resource.data.diamonds == 0
        && request.resource.data.wins == 0
        && request.resource.data.inventory is map
        && request.resource.data.ownedThemes is list
        && request.resource.data.activeTheme == 'default'
        && request.resource.data.lastAction == null
        && request.resource.data.friendCode is string;
      allow update: if signedIn() && request.auth.uid == uid
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['displayName', 'photoURL', 'friendCode', 'diamonds', 'wins', 'inventory', 'ownedThemes', 'activeTheme', 'updatedAt'])
            && request.resource.data.displayName is string
            && request.resource.data.friendCode is string
            && request.resource.data.diamonds == resource.data.get('diamonds', 0)
            && request.resource.data.wins == resource.data.get('wins', 0)
            && request.resource.data.inventory == resource.data.get('inventory', request.resource.data.inventory)
            && request.resource.data.ownedThemes == resource.data.get('ownedThemes', request.resource.data.ownedThemes)
            && request.resource.data.activeTheme == resource.data.get('activeTheme', request.resource.data.activeTheme)
          ) || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeTheme', 'updatedAt'])
            && request.resource.data.ownedThemes.hasAny([request.resource.data.activeTheme])
          ) || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['coins', 'diamonds', 'wins', 'inventory', 'ownedThemes', 'lastAction', 'updatedAt'])
            && request.resource.data.coins is int
            && request.resource.data.coins >= 0
            && request.resource.data.coins <= 100000
            && request.resource.data.diamonds is int
            && request.resource.data.diamonds >= 0
            && request.resource.data.wins is int
            && request.resource.data.wins >= 0
            && request.resource.data.inventory is map
            && request.resource.data.ownedThemes is list
            && request.resource.data.lastAction is map
            && (
              (request.resource.data.lastAction.type == 'power' && validPowerUse(uid))
              || (request.resource.data.lastAction.type == 'reward' && validRoundReward(uid))
              || (request.resource.data.lastAction.type == 'market' && validMarketPurchase())
            )
          ) || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['longestWord', 'bestScore', 'bestScoreWord', 'updatedAt'])
            && request.resource.data.get('longestWord', '') is string
            && request.resource.data.get('bestScore', 0) is int
            && request.resource.data.get('bestScoreWord', '') is string
          )
        );
      allow delete: if false;
    }

    match /handles/{code} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.requestedBy
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 2
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && request.auth.uid in resource.data.members
        && request.auth.uid != resource.data.requestedBy
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if signedIn() && request.auth.uid in resource.data.members;
    }

    match /matchmaking/{uid} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn() && (
        request.auth.uid == uid || (
          resource.data.status == 'waiting'
          && request.resource.data.status == 'matched'
          && request.resource.data.matchedBy == request.auth.uid
          && request.resource.data.roomCode is string
          && existsAfter(/databases/$(database)/documents/rooms/$(request.resource.data.roomCode))
          && getAfter(/databases/$(database)/documents/rooms/$(request.resource.data.roomCode)).data.hostId == request.auth.uid
        )
      );
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    match /invites/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.roomCode is string;
      allow update: if false;
      allow delete: if signedIn() && (request.auth.uid == uid || request.auth.uid == resource.data.fromUid);
    }

    match /{document=**} { allow read, write: if false; }
  }
}
